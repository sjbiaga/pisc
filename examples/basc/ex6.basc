# -*- indent-tabs-mode: nil; -*-

⟦ traces = console ⟧

C(x) = exit x. τ/*println("exited")*/. s2s x?{y}. enter y. τ/*println("entered")*/.

P(x) = expel x. τ/*println("expelled")*/. ν(y) s2s x!{y}. accept y. τ/*println("accepted")*/.

Main = ν(x) "p"[ "c"[ ! .c2p x?{y}. C(y) ] | ν(y) ! .p2c x!{y}. P(y) ]

⟦ snapshot = n ⟧
