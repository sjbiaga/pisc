# -*- indent-tabs-mode: nil; -*-

⟦ traces = console ⟧

C(x) = exit x /*println("exited")*/. s2s x?{y}. enter y /*println("entered")*/.

P(x) = expel x /*println("expelled")*/. ν(y) s2s x!{y}. accept y /*println("accepted")*/.

Main = ν(x) "p"[ "c"[ ! .c2p x?{y}. C(y) ] | ν(y) ! .p2c x!{y}. P(y) ]

⟦ snapshot = n ⟧
