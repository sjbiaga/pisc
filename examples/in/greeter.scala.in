           )
    yield
      ()


  def `b31483e3-c277-419f-8e02-076e10bb1dd0`(en: Set[String], key: String)(^ : String): Set[String] =
    val exc = ( if false then Set.empty
                else if key == "d8330967-8d5d-4d42-a707-d21da8f7a022" then Set("").map(^ + _)
                else if key == "3145c04b-86d7-4268-8492-347798528e1a" then Set("").map(^ + _)
                else if key == "710cbca7-f7e6-4947-a50b-c87cd18e801f" then Set("").map(^ + _)
                else Set.empty )
    val inc = ( if false then Set.empty
                else if key == "d8330967-8d5d-4d42-a707-d21da8f7a022" then Set("710cbca7-f7e6-4947-a50b-c87cd18e801f", "3145c04b-86d7-4268-8492-347798528e1a").map(^ + _)
                else if key == "3145c04b-86d7-4268-8492-347798528e1a" then Set("710cbca7-f7e6-4947-a50b-c87cd18e801f", "d8330967-8d5d-4d42-a707-d21da8f7a022").map(^ + _)
                else if key == "710cbca7-f7e6-4947-a50b-c87cd18e801f" then Set("3145c04b-86d7-4268-8492-347798528e1a", "d8330967-8d5d-4d42-a707-d21da8f7a022").map(^ + _)
                else Set.empty )
    ((en - key).map(^ + _) -- exc) ++ inc
