  def `Greeter`(stdout: `()`, name: `()`): IO[Unit] = // Elvis operator
    for
      _ <- IO.unit
      _ <- ( if (name.substring(0,1).toUpperCase === "Q")
             then
               for
                 _ <- IO.unit
                 _ <- stdout("That's an unusual name.\n")
               yield
                 ()
             else
               for
                 _ <- IO.unit
                 _ <- ( if (name === "Voldemort")
                        then
                          for
                            _ <- IO.unit
                            _ <- stdout("WARNING! LORD VOLDEMORT IS HERE!\n")
                          yield
                            ()
                        else
                          for
                            _ <- IO.unit
                            _ <- stdout(s"Hello $name!\n")
                          yield
                            ()
                      )
               yield
                 ()
           )
    yield
      ()
