  given Conversion[`()`, String] = _.name.asInstanceOf[String]


  def `Main`(): IO[Unit] =
    for
      _ <- IO.unit
      stdin <- `v`
      stdout <- `v`
      _ <- (
             for
               _ <- IO.unit
               _ <- stdout("What's your name?\n")
               name <- stdin()
               _ <- `Greeter`(stdout, name)
             yield
               ()
           ,
             for
               _ <- IO.unit
               prompt <- stdout()
               _ <- IO.print(prompt)
               sc_name <- IO { scala.io.StdIn.readLine }
               _ <- stdin(sc_name)
               pi_greet <- stdout()
               _ <- IO.print(pi_greet)
             yield
               ()
           ).parMapN { (_, _) => }
    yield
      ()

