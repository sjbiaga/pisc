import _root_.scala.collection.immutable.Map

import _root_.cats.effect.{ IO, IOApp, IOLocal, ExitCode, Deferred, Ref }
import _root_.cats.effect.std.{ Queue, Semaphore, Supervisor }

import `ŒÝ-dump`.*
import `ŒÝ-loop`.*
