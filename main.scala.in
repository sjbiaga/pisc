  import _root_.eu.timepit.refined.*

  extension (self: œÄLs[IO[?]])
    private[œÄ] inline def œÄparSequence: IO[Unit] =
      self.parSequence.void

  import sŒÝ.*

  def `œÄ-uuid` = UUID.randomUUID.toString

  def `œÄ-supervised`(io: => IO[Any]): IO[Unit] =
    Supervisor[IO](await = true)
      .use(_.supervise(io))
      .flatMap(_.join.void)

