object App extends IOApp:

  private val spicsp = "pisc.stochastic.communications.parallelism.level"

  private def run(parallelism: Int, started: Ref[IO, Long], args: List[String])(% : %, / : /, * : *, - : -, ! : !, & : &): IO[ExitCode] =
    ( for
        _ <- loop(parallelism, started)(using %, !, &, -, *)(œÄ.`œÄ-wand`).background
        _ <- poll(using %, /, *).background
        _ <- dump(using %, !, -).background
      yield
        ()
    ).use { _ =>
      for
        semaphore  <- Semaphore[IO](2)
        (id, tree) <- sŒÝ.`][`()
        _          <- œÄ.`œÄ-supervised`(œÄ.Main(id)(args*)(using œÄ.`œÄ-uuid`)(using tree, semaphore, %, /, *.offer(())))
        x          <- !.get
      yield
        x
    }

  override def run(args: List[String]): IO[ExitCode] =
    val p = if sys.Prop.IntProp(spicsp).isSet
            then sys.Prop.IntProp(spicsp).value
            else œÄ.`œÄ-parallelism`
    for
      % <- IO.ref(Map[String, Int | +]())
      / <- Queue.unbounded[IO, ((String, String), +)]
      * <- Queue.unbounded[IO, Unit]
      - <- Queue.unbounded[IO, List[String] | (Long, ((Long, Long), Long), (String, String), (Double, Double))]
      ! <- Deferred[IO, ExitCode]
      & <- IO.ref(0L)
      n <- IO.ref(0L)
      _ <- `œÄ-enable`(œÄ.`œÄ-main`)(using %)
      x <- run(p, n, args)(%, /, *, -, !, &)
    yield
      x


object œÄ:

  import _root_.java.util.UUID

